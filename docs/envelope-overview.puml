@startuml
!theme plain
title Envelope encryption — overview (DEK in store, KEK wraps keyset)

rectangle "KEK\n(Key Encryption Key)" as kek #LightBlue
note right of kek
  Production: **Cloud KMS** (GcpKmsAead)
  Simulation: local **Tink AES-GCM**
end note

rectangle "EncryptedKeysetStore\n(GCS or InMemory)" as store #Wheat
note bottom of store
  JSON file: encrypted DEK keyset
  (**TinkJsonProtoKeysetFormat**)
end note

rectangle "DEK keyset\n(AES-128-GCM in Tink)" as dek #LightGreen

kek -down-> store : wrap / unwrap\nkeyset blob
store -down-> dek : after parse with KEK

@enduml
