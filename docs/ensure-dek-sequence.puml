@startuml
!theme plain
title ensureDekOnGcs() — GCS: object must exist (else throw); in-memory: bootstrap if empty

actor Caller
participant "EnvelopeCryptoService" as svc
participant "EncryptedKeysetStore" as store
participant "kekAead()\n(KMS or local)" as kek
participant "Tink generate +\nserializeEncryptedKeyset" as boot

Caller -> svc : ensureDekOnGcs()
alt keyset already present
  svc -> Caller : return
else GCS store, object missing
  svc -> Caller : IllegalStateException\n(no auto-create)
else in-memory (or other) store, empty
  svc -> kek : get AEAD (KEK)
  svc -> boot : generate DEK + serialize
  boot --> svc : JSON
  svc -> store : writeEncryptedKeysetJson(JSON)
  svc -> Caller : return
end

@enduml
