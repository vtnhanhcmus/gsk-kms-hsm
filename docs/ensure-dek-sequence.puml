@startuml
!theme plain
title ensureDekOnGcs() — tạo DEK lần đầu (nếu store chưa có)

actor Caller
participant "EnvelopeCryptoService" as svc
participant "kekAead()\n(KMS hoặc local)" as kek
participant "Tink\nKeysetHandle.generateNew\n(AES128_GCM)" as gen
participant "TinkJsonProtoKeysetFormat\nserializeEncryptedKeyset" as ser
participant "EncryptedKeysetStore" as store

Caller -> svc : ensureDekOnGcs()
alt store đã tồn tại
  svc -> Caller : return
else chưa có keyset
  svc -> kek : lấy primitive AEAD (KEK)
  svc -> gen : sinh keyset DEK mới
  gen --> svc : KeysetHandle (DEK)
  svc -> ser : serializeEncryptedKeyset(DEK, KEK, empty AAD)
  ser --> svc : JSON string
  svc -> store : writeEncryptedKeysetJson(JSON)
  svc -> Caller : return
end

@enduml
